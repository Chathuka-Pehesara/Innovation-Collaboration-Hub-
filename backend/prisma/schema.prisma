// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  projects Project[]
}

model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  projects ProjectTag[]
}

model Skill {
  id       String         @id @default(uuid())
  name     String         @unique
  projects ProjectSkill[]
  users    UserSkill[]
  assessments SkillAssessment[]
}

model Project {
  id          String         @id @default(uuid())
  title       String
  description String
  status      String         @default("Draft")
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  ownerId     String
  teamSize    Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tags        ProjectTag[]
  skills      ProjectSkill[]
  aiResult    AIResult?
  team        Team?
}

model ProjectTag {
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

model ProjectSkill {
  projectId String
  skillId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId])
}

model AIResult {
  id          String   @id @default(uuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  score       Int
  suggestions String   // Can store JSON array of strings
}

model Team {
  id          String         @id @default(uuid())
  projectId   String         @unique
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  members     TeamMember[]
  invites     TeamInvite[]
  tasks       Task[]
  resources   Resource[]
  activities  Activity[]
  chat        Chat?
}

model TeamMember {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String   
  role        String   @default("MEMBER") // LEAD, MEMBER
  joinedAt    DateTime @default(now())

  @@unique([teamId, userId])
}

model TeamInvite {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String   
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  type        String   @default("INVITE") // INVITE, APPLICATION
  createdAt   DateTime @default(now())

  @@unique([teamId, userId])
}

model Task {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, DONE
  assigneeId  String?  // User ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resource {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  uploadedBy  String   // User ID
  createdAt   DateTime @default(now())
}

model Activity {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  action      String
  userId      String   // User who performed the action
  createdAt   DateTime @default(now())
}

model Chat {
  id           String            @id @default(uuid())
  name         String?
  isGroup      Boolean           @default(false)
  teamId       String?           @unique
  team         Team?             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     Message[]
  participants ChatParticipant[]
}

model ChatParticipant {
  id       String   @id @default(uuid())
  chatId   String
  chat     Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime @default(now())

  @@unique([chatId, userId])
}

model Message {
  id        String           @id @default(uuid())
  chatId    String
  chat      Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  content   String?
  fileUrl   String?
  fileName  String?
  fileType  String?
  createdAt DateTime         @default(now())
  receipts  MessageReceipt[]
}

model MessageReceipt {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String   // "TEAM_MESSAGE", "DM_MESSAGE", "SYSTEM"
  title       String
  message     String
  referenceId String?  // ID of the Chat/Team related to the notification
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── Profile Management Models ──────────────────────────────────────────────

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  name                 String
  role                 String         @default("student") // student, mentor, admin
  password             String         // encrypted
  bio                  String?        @db.Text
  specialization       String?        // AI, IT, Cybersecurity, Networking, Other
  avatarUrl            String?
  githubUrl            String?
  linkedinUrl          String?
  portfolioUrl         String?
  twitterUrl           String?
  availableHours       Int            @default(0) // weekly hours available
  availableDays        String         @default("[]") // JSON array of day names
  xp                   Int            @default(0)
  level                Int            @default(1)
  isVerified           Boolean        @default(false)
  verificationToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  skills               UserSkill[]
  skillAssessments     SkillAssessment[]
  portfolioItems       PortfolioItem[]
  refreshTokens        RefreshToken[]
  badges               UserBadge[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserSkill {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  level     String   @default("Beginner") // Beginner, Intermediate, Advanced
  score     Int      @default(0)
  addedAt   DateTime @default(now())

  @@unique([userId, skillId])
}

model PortfolioItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  description String? @db.Text
  url       String?
  imageUrl  String?
  tags      String   @default("[]") // JSON array of tag strings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SkillAssessment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  score     Int      
  passed    Boolean
  createdAt DateTime @default(now())
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique // e.g., "React Novice", "Java Expert"
  description String?
  icon        String?     // e.g. a lucide icon name or emoji
  tier        String      @default("Bronze") // Bronze, Silver, Gold, Platinum
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}
